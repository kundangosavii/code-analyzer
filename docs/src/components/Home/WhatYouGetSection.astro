---
const items = [
  {
    title: "Dependency Graph",
    desc: "Interactive visualization of your entire codebase.",
  },
  {
    title: "Impact Analysis",
    desc: "See what breaks when you change a file.",
  },
  {
    title: "File Insights",
    desc: "Detailed per-file breakdown with real metrics.",
  },
];
---

<section class="bg-[#f5f0e9] text-black dark:bg-[#000000] dark:text-white py-20 px-6">
  <div class="max-w-6xl mx-auto">

    <h2 class="text-3xl md:text-4xl font-bold mb-4">
      What you <span class="text-orange-600"> actually </span> get.
    </h2>

    <p class="text-gray-400 mb-12">
      Not just analysis—real insights you can use immediately.
    </p>

    <div class="grid md:grid-cols-3 gap-6">
      {items.map((item) => (
        <div class="border border-gray-400 rounded-xl p-6 hover:border-gray-600 transition">
          <h3 class="text-lg font-medium mb-2">{item.title}</h3>
          <p class="text-gray-400 text-sm">{item.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>