---
---

<section class="relative isolate overflow-hidden px-4 pb-24 sm:px-6 lg:px-8">
	<div class="absolute inset-x-0 top-0 -z-20 h-40 bg-[#f5f0e9] dark:bg-[#000000]" />

	<div class="mx-auto w-4xl max-w-7xl">

		<div class="overflow-hidden rounded-[1rem] border border-black/10 bg-zinc-950 shadow-[0_35px_100px_rgba(0,0,0,0.2)] ring-1 ring-white/10 dark:border-white/10">
			<div class="flex items-center justify-between border-b border-white/10 bg-white/5 px-5 py-4 sm:px-6">
				<div class="flex items-center gap-2">
					<span class="h-3 w-3 rounded-full bg-[#ff5f57]" />
					<span class="h-3 w-3 rounded-full bg-[#febc2e]" />
					<span class="h-3 w-3 rounded-full bg-[#28c840]" />
				</div>
				<div class="text-xs font-bold tracking-[0.25em] text-white/55">
					CodeSync
				</div>
				<div class="w-12" />
			</div>

			<div class="relative aspect-[16/9] bg-[#0f1115] sm:aspect-[16/8]">
				<video
					class="h-full w-full object-cover opacity-95"
					autoplay
					muted
					loop
					playsinline
					poster="/images/hero-video-poster.jpg"
				>
					<source src="/videos/codesync-demo.webm" type="video/webm" />
					<source src="/videos/codesync-demo.mp4" type="video/mp4" />
				</video>

				<div class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.12),rgba(0,0,0,0.42))]" />
				<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(98,255,198,0.12),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(255,189,89,0.16),transparent_30%)]" />
			</div>
		</div>
	</div>
</section>